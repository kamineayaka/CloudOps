# Copy to .env and fill in before deploying:
#   cp .env.example .env

# --- Platform secrets (leave empty to auto-generate on first boot) ---
JWT_SECRET=
CREDENTIALS_MASTER_KEY=

# --- Database ---
POSTGRES_DB=archops
POSTGRES_USER=archops
POSTGRES_PASSWORD=archops

# --- MinIO ---
MINIO_ROOT_USER=archops
MINIO_ROOT_PASSWORD=archops123

# --- HTTP ---
HTTP_PORT=80
CORS_ALLOWED_ORIGINS=http://localhost,http://your-server-ip

# --- AI (optional seed migration; configure providers in admin UI after deploy) ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Legacy env vars below are ignored when providers are configured in the UI.
AI_DEFAULT_PROVIDER=openai-compat
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b
RAG_ENABLED=true
RAG_PROVIDER=openai-compat
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.35
