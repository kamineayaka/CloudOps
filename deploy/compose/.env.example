# Copy to .env and fill in before deploying:
#   cp .env.example .env

# --- Required secrets (change before production!) ---
JWT_SECRET=change-me-use-openssl-rand-base64-32-at-least-32-chars
CREDENTIALS_MASTER_KEY=change-me-another-32-byte-secret-key!!

# --- Database ---
POSTGRES_DB=cloudops
POSTGRES_USER=cloudops
POSTGRES_PASSWORD=cloudops

# --- MinIO ---
MINIO_ROOT_USER=cloudops
MINIO_ROOT_PASSWORD=cloudops123

# --- HTTP ---
HTTP_PORT=80
CORS_ALLOWED_ORIGINS=http://localhost,http://your-server-ip

# --- AI / LLM ---
# Provider: openai-compat | ollama
AI_DEFAULT_PROVIDER=openai-compat
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama (when AI_DEFAULT_PROVIDER=ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b

# --- RAG / Embeddings ---
RAG_ENABLED=true
# Embedding provider: openai-compat | ollama (independent of chat LLM provider)
RAG_PROVIDER=openai-compat
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.35
# When using Ollama for embeddings:
# RAG_PROVIDER=ollama
# RAG_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# RAG_OLLAMA_EMBEDDING_DIMENSIONS=768
